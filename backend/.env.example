# FairHire API Keys Template
# ------------------------------------
# Rename this file to `.env` or create a `.env` file in the root directory
# and replace the placeholders below with your actual keys.

# Gemini API Key for AI Resumé Analysis (Required)
# Get a key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# HuggingFace Token (Optional: Only if you fallback to HuggingFace models)
HF_TOKEN=hf_your_token_here
